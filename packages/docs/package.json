{
  "name": "cheetah-grid-docs",
  "private": true,
  "version": "2.1.0",
  "scripts": {
    "watch": "vitepress dev . --open",
    "build": "npm-run-all build:*",
    "build:vuedoc": "node ./scripts/vuedoc/build.js",
    "build:vitepress": "vitepress build .",
    "_build:jsdoc": "jsdoc ./../cheetah-grid/src/js -c jsdoc-conf.js",
    "build:tsdoc": "typedoc --options typedoc.js --tsconfig ../cheetah-grid/tsconfig.json"
  },
  "devDependencies": {
    "@babel/parser": "^7.26.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdoc": "^3.6.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typedoc": "^0.28.10",
    "typescript": "^5.9.2",
    "vue-eslint-parser": "^10.4.0",
    "vitepress": "^1.5.0",
    "vitepress-plugin-llms": "^1.9.1"
  }
}
