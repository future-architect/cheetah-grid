{
  "name": "cheetah-grid",
  "version": "2.1.1",
  "description": "Cheetah Grid is a high performance grid engine that works on canvas",
  "keywords": [
    "spreadsheet",
    "grid",
    "table",
    "data",
    "canvas",
    "cheetah",
    "datagrid",
    "datatable"
  ],
  "main": "dist/main.mjs",
  "unpkg": "dist/main.umd.js",
  "exports": {
    ".": {
      "types": "./dist/main.d.mts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.umd.js",
      "default": "./dist/main.mjs"
    },
    "./main.mjs": "./dist/main.mjs",
    "./main.css": "./dist/main.css",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/future-architect/cheetah-grid.git"
  },
  "author": {
    "name": "Yosuke Ota",
    "email": "otameshiyo23@gmail.com",
    "url": "https://www.npmjs.com/~ota-meshi"
  },
  "contributors": [],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/future-architect/cheetah-grid/issues",
    "email": "gr-tig-oss@future.co.jp"
  },
  "homepage": "https://future-architect.github.io/cheetah-grid/",
  "files": [
    "src/js/",
    "dist/",
    "tools/src/"
  ],
  "scripts": {
    "test": "vitest run",
    "lint": "pnpm run eslint && pnpm run stylelint && pnpm run tsc",
    "test:once": "pnpm run test",
    "test:watch": "vitest",
    "test:ff": "cross-env VITEST_BROWSER=firefox vitest run",
    "test:chrome": "cross-env VITEST_BROWSER=chromium VITEST_BROWSER_CHANNEL=chrome vitest run",
    "build": "pnpm run build:tsdown && pnpm run test:node",
    "build:tsdown": "tsdown",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "stylelint": "stylelint \"**/*.css\"",
    "stylelint:fix": "stylelint \"**/*.css\" --fix",
    "tsc": "tsc --project ./tsconfig.json",
    "test:node": "node ./dist/main.umd.js",
    "build:ci": "pnpm run build",
    "coverage": "vitest run --coverage",
    "coverage:remap": "pnpm run coverage",
    "coverage:open": "open coverage/index.html"
  },
  "directories": {
    "src": "src/js",
    "test": "src/test/specs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/browser": "^4.1.6",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^7.0.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "image-matcher": "^0.1.4",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "rolldown": "^1.0.1",
    "stylelint": "^13.6.1",
    "stylelint-config-standard": "^20.0.0",
    "tsdown": "^0.14.1",
    "typescript": "^5.9.2",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "last 2 versions"
  ]
}
